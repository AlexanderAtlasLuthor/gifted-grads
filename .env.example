# Frontend env vars (must be prefixed with VITE_ to be exposed)
# Leave empty to use same-origin (Cloudflare Pages Functions)
VITE_API_BASE_URL=""

# In npm run dev, mock mode is automatic when VITE_API_BASE_URL is empty.
# Set to "false" to force the real backend, or "true" to force mock mode.
VITE_USE_MOCK_API="false"
