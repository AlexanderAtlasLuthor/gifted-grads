# Frontend env vars (must be prefixed with VITE_ to be exposed)
# Leave empty to use same-origin (Cloudflare Pages Functions)
VITE_API_BASE_URL=""

# In npm run dev, mock mode is automatic when VITE_API_BASE_URL is empty.
# Set to "false" to force the real backend, or "true" to force mock mode.
VITE_USE_MOCK_API="false"

# Jotform Form IDs (obtained from each form's URL: https://form.jotform.com/{ID})
# These are the live production form IDs; override only for staging.
VITE_JOTFORM_FORM_ID_ES="261466146136154"
VITE_JOTFORM_FORM_ID_EN="261466352850055"
